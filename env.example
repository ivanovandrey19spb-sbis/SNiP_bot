# =============================================================================
# Шаблон окружения: скопируйте в .env и заполните.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Telegram (обязательно для bot.py)
# -----------------------------------------------------------------------------
BOT_TOKEN=

# -----------------------------------------------------------------------------
# 2. LLM (OpenRouter, OpenAI-совместимый API) — обязательно для bot.py
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
OPENROUTER_BASE_URL=https://api.openai.com/v1  # https://openrouter.ai/api/v1
OPENROUTER_MODEL=gpt-4.1-mini  # openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=
# HTTP timeout и retry в llm_compat.py
# OPENROUTER_TIMEOUT_SEC=90
# OPENROUTER_MAX_RETRIES=2
# OPENROUTER_RETRY_BASE_SEC=1.0

# -----------------------------------------------------------------------------
# 3. Поведение бота (bot.py): история, лимиты, старт
# -----------------------------------------------------------------------------
MAX_HISTORY_MESSAGES=10
RAG_TOP_K=30
CHAT_DB_PATH=./data
# SUPABASE_CHAT_PRIMARY=1
# LOCAL_CHAT_BACKUP_QA_PAIRS=5
# MAX_USER_MESSAGE_CHARS=4000
# MAX_LLM_USER_BLOB_CHARS=12000
# BOT_STARTUP_LLM_CHECK=1

# -----------------------------------------------------------------------------
# 4. Логирование
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

INTERACTION_JSONL_ENABLED=1
INTERACTION_JSONL_VERBOSE=0
# INTERACTION_LOG_PATH=./data
# INTERACTION_LOG_CHUNK_MAX_CHARS=8000
# INTERACTION_LOG_ANSWER_MAX_CHARS=50000
INTERACTION_DB_ENABLED=1
# INTERACTION_DB_PATH=./data

# -----------------------------------------------------------------------------
# 5. Системный промпт (многострочное значение в кавычках поддерживает python-dotenv)
# -----------------------------------------------------------------------------
SYSTEM_PROMPT='Ты экспертный, в меру дружелюбный, но не фамильярный помощник в Telegram 
по нормативной документации (строительные и технические регламенты). 
Работаешь в формате официальных ответов (как ответы органов экспертизы).'

# -----------------------------------------------------------------------------
# 6. Supabase (подключение, RAG, зеркало чата)
# -----------------------------------------------------------------------------
SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLIC_KEY_LONG=
SUPABASE_EMAIL=
SUPABASE_PASSWORD=

# SUPABASE_HEALTHCHECK_TABLE=

# RAG_SUPABASE_LIMIT_PER_TOKEN=
# RAG_SUPABASE_MAX_TOKENS=
# RAG_SUPABASE_WORKSPACE_ID=
# RAG_STOPWORDS_ENABLED=1
RAG_DEBUG=0
# RAG_MODE=unknown

# SUPABASE_CHAT_PRIMARY=1
# SUPABASE_CHAT_MIRROR=0
# SUPABASE_USER_RESOLVE_MODE=db
# TELEGRAM_USER_MAP_PATH=./data
# SUPABASE_SESSION_MAP_PATH=./data
# SUPABASE_DEFAULT_PROJECT_ID=

# verify_supabase_message_write.py — этапный smoke-тест записи/чтения messages
# SUPABASE_SMOKE_TEST_USER_ID=
# SUPABASE_SMOKE_TEST_PROJECT_ID=
# SUPABASE_SMOKE_CLEANUP=1

# -----------------------------------------------------------------------------
